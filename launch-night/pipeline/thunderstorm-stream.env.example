# /etc/thunderstorm-stream.env — loaded by systemd EnvironmentFile=
#
# chmod 600 /etc/thunderstorm-stream.env
# chown root:root /etc/thunderstorm-stream.env
#
# Stream key is sensitive — never commit a populated copy to git.

YT_STREAM_KEY=xxxx-xxxx-xxxx-xxxx-xxxx
VIDEO_LOOP_PATH=/home/atlas/youtube-stream/assets/thunderstorm-loop.mp4
AUDIO_LOOP_PATH=/home/atlas/youtube-stream/assets/thunderstorm-audio.mp3
